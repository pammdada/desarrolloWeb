# Root ignore file for the project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and editors
.vscode/
.idea/
*.iml
*.ipr
*.iws

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java / Maven
**/target/
**/build/
*.class
*.jar
*.war
*.ear
hs_err_pid*
.recommenders/

# Maven wrapper
.mvn/wrapper/maven-wrapper.jar

# Spring Boot
spring.log

# Node / Angular
/front/node_modules/
/front/dist/
/front/out-tsc/
/front/.angular/
/front/.cache/
/front/.tmp/

# Test reports and coverage
coverage/
**/coverage/
.nyc_output/
*.lcov

# Generated files
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# Misc
.env
.env.local
.env.*.local

# Optional workspace artifacts
*.class
*.log
